# Copy to .env in the relevant workspace and fill real values. NEVER commit .env.
# Secrets (MONGODB_URI, keys, admin creds, JWT_SECRET) live server-side only.

# --- backend/.env ---
PORT=5000
# Local dev MongoDB. Use a MongoDB Atlas connection string in production.
MONGODB_URI=mongodb://127.0.0.1:27017/sagar_portfolio
# Frontend origin allowed by CORS.
CORS_ORIGIN=http://localhost:3000

# Admin panel login.
ADMIN_USER=
ADMIN_PASSWORD=
JWT_SECRET=

# Contact-form email notification. Optional — messages are stored in the
# database regardless. Brevo HTTP API preferred in production (SMTP ports are
# often blocked on free hosts); Gmail SMTP works for local dev.
BREVO_API_KEY=
SMTP_USER=
SMTP_PASS=
CONTACT_TO=

# AI draft assist (server-side only, never exposed to the client).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- frontend/.env.local ---
# Base URL of the backend API (non-secret; safe to expose).
NEXT_PUBLIC_API_URL=http://localhost:5000
# Public URL of the site (used for SEO metadata, sitemap, JSON-LD).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

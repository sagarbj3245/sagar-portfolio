# Copy to .env in the relevant workspace and fill real values. NEVER commit .env.
# Secrets (MONGODB_URI, LLM_API_KEY, admin creds, JWT_SECRET) live server-side only.

# --- backend/.env ---
PORT=5000
# Local dev MongoDB (already running). Atlas connection string used in production (Story 1.5).
MONGODB_URI=mongodb://127.0.0.1:27017/sagar_portfolio
# Frontend origin allowed by CORS (Story 1.2+).
CORS_ORIGIN=http://localhost:3000
# Added in later stories:
# JWT_SECRET=            # admin auth (Story 5.1)
# ADMIN_USER=           # admin login (Story 5.1)
# ADMIN_PASSWORD=       # admin login (Story 5.1)
# LLM_API_KEY=          # AI draft assist (Story 4.3) — server-side only

# --- frontend/.env.local ---
# Base URL of the backend API (non-secret; safe to expose).
NEXT_PUBLIC_API_URL=http://localhost:5000
